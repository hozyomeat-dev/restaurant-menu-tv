    {
      "id": "story-awa-kuro-gyu",
      "title": "阿波黒牛",
      "subtitle": "AWA KURO USHI",
      "lead": "黒毛和牛 × ホルスタイン、\nその\"ええとこ取り\"。",
      "body": "吉野川の伏流水と高栄養飼料で、26ヶ月以上の長期肥育。\n2016年、徳島県知事認定「とくしま三つ星ビーフ」。",
      "accent": "#c0392b",
      "badge": "とくしま三つ星ビーフ",
      "image": "https://images.unsplash.com/photo-1777898967209-2d124602a601?w=1920&q=80&auto=format&fit=crop",
      "showAtStart": true
    },
    {
      "id": "story-awa-odori",
      "title": "阿波尾鶏",
      "subtitle": "AWA-ODORI",
      "lead": "JAS規格地鶏、\n生産量 全国1位。",
      "body": "徳島の軍鶏（シャモ）× ホワイトプリマスロック の交配種。\n全期間平飼い、75日以上育てる、徳島が誇るブランド地鶏。",
      "accent": "#d68a3a",
      "badge": "JAS地鶏 全国1位",
      "image": "https://images.unsplash.com/photo-1548550023-2bdb3c5beed7?w=1920&q=80&auto=format&fit=crop",
      "showAtStart": true,
      "insertBefore": "prem-tebasaki"
    },
    {
      "id": "story-kimoto-noen",
      "title": "木本農園",
      "subtitle": "KIMOTO FARM",
      "lead": "鳴門の砂地で、\n代々受け継ぐ、なると金時。",
      "body": "瀬戸内の温暖な気候と、海のミネラルを含んだ砂地の畑。\n栗のようなホクホクの食感と、上品な甘さを、お食事の最後に。",
      "accent": "#d4a574",
      "badge": "なると金時",
      "image": "https://images.unsplash.com/photo-1730815048561-45df6f7f331d?w=1920&q=80&auto=format&fit=crop",
      "showAtStart": true,
      "insertBefore": "shime-kintoki"
    }
  ],
