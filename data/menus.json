  "stories": [
    {
      "id": "story-awa-kuro-gyu",
      "title": "阿波黒牛",
      "subtitle": "Awa Kuroge Wagyu — 徳島が育てた、知る人ぞ知る黒毛和牛",
      "lead": "やわらかさと、噛みしめる旨味の両立。",
      "body": "四国山地の清流と、阿波の豊かな自然のなかで、ストレスをかけずに大切に育てられる阿波黒牛。脂の甘さと、しっとりとした赤身の旨味を併せ持つ、徳島のブランド和牛です。\n\n当店ではその「赤身」の魅力を最大限に引き出すため、希少部位を厳選。一口ごとに、生産者の想いが伝わる肉を、ぜひお楽しみください。",
      "accent": "#c0392b",
      "badge": "ブランド和牛"
    },
    {
      "id": "story-awa-odori",
      "title": "阿波尾鶏",
      "subtitle": "Awa-Odori — 徳島が誇るブランド地鶏",
      "lead": "ふつうの鶏の、ちょうど倍の時間を。",
      "body": "広々とした鶏舎で、阿波尾鶏は約80日間という、一般的なブロイラーの倍以上の時間をかけて、のびのびと育てられます。\n\nその結果生まれるのは、噛みごたえのある弾力、深い旨味、そして指で皮を裂くだけで溢れるジューシーさ。手羽先を炭火で香ばしく焼き上げ、阿波尾鶏ならではの素材の力を、ストレートにお届けします。",
      "accent": "#d68a3a",
      "badge": "ブランド地鶏"
    },
    {
      "id": "story-kimoto-noen",
      "title": "木本農園",
      "subtitle": "Kimoto Farm — 鳴門海峡が育てる、潮風と砂の畑",
      "lead": "あまじょっぱい、最後の一皿のために。",
      "body": "徳島県鳴門市。海峡から吹き抜ける潮風と、ミネラルを含んだ砂地の畑で、木本農園は代々「鳴門金時」を育ててきました。\n\n自然そのものの甘さと、ホクッとほどける食感。揚げたての金時に、冷たいバニラアイスを添えて——。一日の食事の、最後を彩る一皿になればと願って、この農家のさつまいもを選んでいます。",
      "accent": "#d4a574",
      "badge": "産地直送"
    }
  ],
